---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('pages');
const entries = allEntries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const rotations = [-3, 2, -1.5, 1, -2.5, 2.5, -0.5, 3, -2, 1.5, -3.5, 0.5, -1, 2, -2];
---
<Base title="For Antero, with everything I have">
<div class="paper">

  <div class="page-title">
    <h1>for Antero ♡</h1>
    <p>a little collection of reasons and moments, just for you</p>
  </div>

  <div class="collage">
    {entries.map((entry, i) => {
      const rot = rotations[i % rotations.length];
      const wide = entry.data.wide ? ' wide' : '';
      const k = entry.data.kind;

      if (k.startsWith('sticky')) {
        return (
          <div class={`item sticky ${k}${wide}`} style={`--rot:${rot}deg`} tabindex="0">
            <div class="sticky-title">{entry.data.title}</div>
            <div class="sticky-body">{entry.data.body}</div>
            {entry.data.tag && <div class="sticky-tag">{entry.data.tag}</div>}
          </div>
        );
      }

      if (k === 'note') {
        return (
          <div class={`item note${wide}`} style={`--rot:${rot}deg`} tabindex="0">
            <div class="note-title">{entry.data.title}</div>
            <div class="note-body">{entry.data.body}</div>
            {entry.data.tag && <div class="note-tag">{entry.data.tag}</div>}
          </div>
        );
      }

      if (k === 'letter') {
        return (
          <div class={`item letter${wide}`} style={`--rot:${rot}deg`} tabindex="0">
            <div class="letter-label">a moment</div>
            <div class="letter-title">{entry.data.title}</div>
            <div class="letter-body">{entry.data.body}</div>
          </div>
        );
      }

      if (k.startsWith('washi')) {
        return (
          <div class={`item washi ${k}${wide}`} style={`--rot:${rot}deg`} tabindex="0">
            <span class="washi-text">{entry.data.title}</span>
            <div class="washi-tip">{entry.data.body}</div>
          </div>
        );
      }

      return null;
    })}
  </div>

  <div class="page-footer">
    <span>♡</span>
  </div>
</div>
</Base>
